# ================================================================
# LEDGERA — Environment Variables Guide
# ================================================================
# Copy this file to .env.local and fill in every value.
# Variables marked [REQUIRED] must be set before the app runs.
# Variables marked [OPTIONAL] have safe fallbacks but should be
# configured for production.
# ================================================================

# ================================================================
# 1. DATABASE  (Prisma / PostgreSQL)
# ================================================================
# [REQUIRED] Your PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ledgera?schema=public"

# ================================================================
# 2. AUTHENTICATION — JWT
# ================================================================
# [REQUIRED] A long, random string used to sign session JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="generate-a-32-byte-random-hex-string-here"

# ================================================================
# 3. GOOGLE OAUTH
# ================================================================
# [REQUIRED] Google Cloud Console → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type).
#
# Authorized JavaScript origins:
#   http://localhost:6969 (dev)
#   https://yourdomain.com (prod)
#
# Authorized redirect URIs:
#   http://localhost:6969 (dev)
#   https://yourdomain.com (prod)

# Client ID — used on both server (route handler) and client (GoogleOAuthProvider)
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_ID="same_as_above_for_server_side_verification"

# Client Secret — SERVER SIDE ONLY, never expose to the client
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ================================================================
# 4. CLOUDFLARE TURNSTILE  (Bot protection / CAPTCHA)
# ================================================================
# [REQUIRED] https://dash.cloudflare.com/turnstile
# Turnstile protects your login endpoints from bots.
# Get free site + secret keys from the Cloudflare dashboard.
#
# NOTE: The dummy key "1x00000000000000000000AA" below
#       is Cloudflare's test key — it ALWAYS passes verification.
#       DO NOT use it in production.

# Public key — safe to expose to the client
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAD3_rLqYQ6jicPry"

# Secret key — SERVER SIDE ONLY, never expose to the client
TURNSTILE_SECRET_KEY="your_turnstile_secret_key"

# ================================================================
# 5. MICROSOFT OAUTH  (Optional — Azure AD / Entra ID)
# ================================================================
# [OPTIONAL] Azure Portal → App registrations
# Only needed if you want Microsoft / Outlook / Azure AD login.
#
# Setup steps:
#   1. Register app at https://portal.azure.com → Azure Active Directory
#   2. Add redirect URI: http://localhost:6969/auth/microsoft/callback
#   3. Create Client Secret under "Certificates & secrets"
#   4. Enable ID tokens under "Authentication" → "Advanced settings"
#
# Required scopes: openid profile email User.Read

# Public key — safe to expose to the client
NEXT_PUBLIC_MICROSOFT_CLIENT_ID="your_microsoft_application_client_id"

# Redirect URI — must match exactly what you registered in Azure
NEXT_PUBLIC_MICROSOFT_REDIRECT_URI="http://localhost:6969/auth/microsoft/callback"

# Server-side only — NEVER expose to the client
MICROSOFT_CLIENT_ID="your_microsoft_application_client_id"
MICROSOFT_CLIENT_SECRET="your_microsoft_client_secret"

# ================================================================
# 6. WALLETCONNECT v2  (Web3 wallet connections)
# ================================================================
# [REQUIRED for wallet connect] https://cloud.walletconnect.com
# Free to register. Creates a Project ID that identifies your dApp.
#
# Setup:
#   1. Go to https://cloud.walletconnect.com
#   2. Sign in with email or wallet
#   3. Create a new project → copy the Project ID
#   4. Paste it below

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your_walletconnect_project_id"

# ================================================================
# 7. PUBLIC API URL
# ================================================================
# [OPTIONAL] Used by frontend to call your own API routes.
NEXT_PUBLIC_API_URL="http://localhost:6969/api"

# -----------------------------------------------------------------------------
# 8. IDR STABLECOIN CONTRACT ADDRESSES (BNB Chain Testnet)
# -----------------------------------------------------------------------------
#This is the real address of IDRX and IDRT Smart Contract
NEXT_PUBLIC_IDRX_CONTRACT_ADDRESS=0x337610d27c682E347C9cD60BD4b3b107C9d34dDd
NEXT_PUBLIC_IDRT_CONTRACT_ADDRESS=0x2b34b49071c50d97d87b1c3125dd48ee3e7eebb0 

# -----------------------------------------------------------------------------
# 9. BLOCKCHAIN RPC ENDPOINT
# -----------------------------------------------------------------------------
# Using Public RPC BNB Testnet (used on viemClient)
NEXT_PUBLIC_BNB_TESTNET_RPC=https://bsc-testnet.blockpi.network/v1/rpc/public

# ================================================================
# QUICK REFERENCE — WHAT NEEDS WHAT
# ================================================================
#
#  To run locally with FULL functionality, you need:
#
#  ✅ JWT_SECRET              → Generate a random string
#  ✅ DATABASE_URL            → Local PostgreSQL or cloud Postgres
#  ✅ GOOGLE_CLIENT_ID/SECRET → cloud.google.com (OAuth 2.0)
#  ✅ NEXT_PUBLIC_GOOGLE_CLIENT_ID → Same Google Client ID
#  ✅ TURNSTILE_KEYS         → dash.cloudflare.com/turnstile
#
#  To enable Microsoft login (optional):
#  ✅ MICROSOFT_* vars       → portal.azure.com
#
#  To enable WalletConnect (recommended):
#  ✅ WALLETCONNECT_PROJECT_ID → cloud.walletconnect.com
#
#  DUMMY/TEST values (only for local dev — DO NOT use in prod):
#  ✅ Turnstile test key: 1x00000000000000000000AA (always passes)
