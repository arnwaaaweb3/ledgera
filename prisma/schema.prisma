// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enum untuk Status Transaksi agar Typesafe
enum TransactionStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

// Enum untuk Kategori Transaksi
enum TransactionCategory {
  PERSONAL
  PROCUREMENT
  BUSINESS
}

// Enum untuk Provider IDR Stablecoin (Adapter Layer)
enum IdrStablecoinIssuer {
  IDRX        // IDRX Token
  IDRT        // IDRT Token
  BI_CBDC     // Digital Rupiah (Bank Indonesia)
}

// 1. MODEL USER
model User {
  id              String          @id @default(cuid()) 
  email           String          @unique
  username        String?         @unique
  password        String?   
  displayName     String?
  avatarSeed      String?

  // Status Verifikasi & OAuth Provider
  isEmailVerified Boolean         @default(false)
  isVerified      Boolean         @default(false) // Untuk centang hijau/biru serbaguna
  authProvider    String          @default("EMAIL") // "GOOGLE", "MICROSOFT", "EMAIL", "WALLET"

  walletAddress   String          @unique 
  googleSub       String?         @unique 
  microsoftSub    String?         @unique
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  projects        Project[]
  sentTx          Transaction[]   @relation("SenderRelation")
  receivedTx      Transaction[]   @relation("RecipientRelation")
}

// 2. MODEL PROJECT: Pengelompokan transaksi P2P (Project-centric Grouping)
model Project {
  id           String        @id @default(uuid())
  name         String
  description  String?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  transactions Transaction[]

  @@index([userId])
}

// 3. MODEL TRANSACTION: Metadata, kategori P2P, link Smart Contract BNB + Arweave/Irys
model Transaction {
  id              String              @id @default(uuid())
  projectId       String
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title           String
  amount          Decimal             // Presisi desimal tinggi untuk nominal Rupiah / Stablecoin
  
  // 🌟 IDR STABLECOIN ADAPTER METADATA
  issuer          IdrStablecoinIssuer @default(IDRX)
  tokenAddress    String?             // Address smart contract token IDR di EVM
  chainId         Int                 @default(97) // 97 = BNB Chain Testnet
  
  descriptionHash String?             // Optional: IPFS / Off-chain metadata hash
  evidenceUrl     String?             // Tambahan: Bukti pembayaran / foto milestone escrow
  arweaveTxId     String?             // Permanent audit log ID dari Arweave/Irys
  
  category        TransactionCategory @default(PERSONAL)
  status          TransactionStatus   @default(PENDING)
  
  senderId        String
  sender          User                @relation("SenderRelation", fields: [senderId], references: [id])
  
  recipientId     String
  recipient       User                @relation("RecipientRelation", fields: [recipientId], references: [id])
  
  txHash          String?             // BNB Chain transaction hash untuk Judge Mode
  createdAt       DateTime            @default(now())

  @@index([projectId])
  @@index([senderId])
  @@index([recipientId])
}